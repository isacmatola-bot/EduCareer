# Frontend variables used by Vite. The anon key is public by design.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Server-side Supabase Edge Function secret. Never expose this to Vite/Vercel.
# Set it with: supabase secrets set EDUCAREER_SECRET_KEY=sb_secret_...
EDUCAREER_SECRET_KEY=sb_secret_your_secret_key
